          </div>
          <div className="flex items-center gap-6">
             <div className="text-right border-r pr-6 border-slate-200">
                <p className="text-[10px] font-bold text-slate-400 uppercase tracking-widest">Reporting Period</p>
                <p className="text-sm font-bold uppercase tracking-tight">March 2026</p>
             </div>
