/**
 * BRANDING CONSTANTS
 * Primary Navy: #00213B
 * Primary Red: #E31B23
 * Background: #F8FAFC
 * Border Radius: 4px (Sharp/Professional)
 */

const LOGO_URL = "https://i.ibb.co/Lhb8pB3/Daniel-Ahart-logo-FULL-COLOR.png";

const App = () => {
  const [role, setRole] = useState('office'); // 'admin' or 'office'
  const [activeTab, setActiveTab] = useState('dashboard');
  
  // Sub-Office State
  const [formData, setFormData] = useState({
    tax: '',
    bookkeeping: '',
    insurance: '',
    other: ''
  });

  const royaltyRate = 0.07;
  const advertisingRate = 0.02;

  const calculations = useMemo(() => {
    const gross = (parseFloat(formData.tax) || 0) + 
                  (parseFloat(formData.bookkeeping) || 0) + 
                  (parseFloat(formData.insurance) || 0) + 
                  (parseFloat(formData.other) || 0);
    return {
      gross,
      royalty: gross * royaltyRate,
      advertising: gross * advertisingRate,
      totalDue: (gross * royaltyRate) + (gross * advertisingRate)
    };
  }, [formData]);

  const navItems = role === 'office' ? [
    { id: 'dashboard', label: 'Dashboard', icon: LayoutDashboard },
    { id: 'reports', label: 'Past Reports', icon: FileText },
    { id: 'account', label: 'Account Settings', icon: Settings },
